
{
  "manifest_version": 1,
  "name": "JMComic 漫画插件（JMComic-Plugin-for-MaiBot）",
  "version": "1.0.0",
  "description": "基于 JMComic-Crawler-Python 的禁漫天堂漫画下载插件，支持漫画搜索、章节下载、合并转发等功能",
  "author": {
    "name": "geffnt",
    "url": "https://github.com/geffnt"
  },
  "license": "MIT",
  "host_application": {
    "name": "MaiBot",
    "min_version": "0.11.0"
  },
  "homepage_url": "",
  "repository_url": "",
  "keywords": [
    "jmcomic",
    "comic",
    "manga",
    "漫画",
    "禁漫"
  ],
  "categories": [
    "Utility Tools"
  ],
  "default_locale": "zh-CN",
  "plugin_info": {
    "is_built_in": false,
    "plugin_type": "extension",
    "components": [
      {
        "type": "command",
        "name": "JMComicCommand",
        "description": "从 JMComic 搜索和下载漫画",
        "pattern": "^(/jm|jm漫画|禁漫)\\s*(?P<args>.*)?$",
        "usage": "/jm <子命令> [参数]",
        "examples": [
          "/jm search 魔法少女",
          "/jm info 123456",
          "/jm download 123456 1"
        ]
      }
    ],
    "features": [
      "搜索 JMComic 漫画",
      "获取漫画详情和章节列表",
      "下载指定章节",
      "合并转发格式发送图片",
      "支持代理设置",
      "支持账号登录",
      "用户冷却时间控制",
      "单张发送图片模式",
      "可配置单次发送页数上限"
    ],
    "dependencies": {
      "python": [
        "jmcomic"
      ],
      "plugins": [],
      "external_api": [
        "JMComic (禁漫天堂)"
      ]
    },
    "config": {
      "has_config": true,
      "config_file": "config.toml"
    }
  },
  "permissions": [
    "send.image",
    "send.text",
    "send.forward",
    "network.http",
    "filesystem.read",
    "filesystem.write"
  ],
  "id": "geffnt.jmcomic-plugin"
}

